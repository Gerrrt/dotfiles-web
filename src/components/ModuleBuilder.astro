---
// Custom install builder. Toggle modules → get a copy/paste one-liner that passes
// the selection as a positional ARGUMENT to the static /install (bash) or
// /install.ps1 (PowerShell) scripts. No server, no query-string reflection — the
// selection only ever changes the trailing `bash -s -- <modules>` arg, which the
// script validates against its allowlist locally. (Re-themed from the original
// Tailwind blueprint into the site's Tokyo Night system.)
import { modules, defaultTokens } from '../data/modules';

// Absolute base URL baked in at build time so the copied command points at the real
// deployed site (e.g. https://gerrrt.github.io/dotfiles-web/) even when copied from
// a local dev server.
// Normalise to a no-trailing-slash base; BASE_URL may or may not carry one
// depending on the `base`/`trailingSlash` config, so build paths explicitly.
const base = new URL(import.meta.env.BASE_URL, Astro.site ?? 'https://gerrrt.github.io').href.replace(/\/$/, '');
const unixDefault = defaultTokens('unix');
const winDefault = defaultTokens('windows');

const unixCmd = `curl -sS ${base}/install | bash -s -- ${unixDefault}`;
const winCmd = `& ([scriptblock]::Create((irm '${base}/install.ps1'))) ${winDefault}`;
---

<div class="card builder" id="module-builder" data-base={base}>
  <div class="builder__head">
    <h3>
      <span class="builder__pulse" aria-hidden="true"></span> Custom builder
    </h3>
    <p class="muted">
      Toggle modules to generate your install command. Modules ride in as a script
      argument and are validated against an allowlist on your machine — nothing from
      the URL is ever piped into your shell.
    </p>
  </div>

  <fieldset class="builder__mods">
    <legend class="sr-only">Modules</legend>
    {
      modules.map((m) => (
        <label class="modrow">
          <input
            type="checkbox"
            class="modrow__cb"
            data-id={m.id}
            data-platforms={m.platforms.join(',')}
            checked={m.defaultOn}
          />
          <span class="modrow__body">
            <span class="modrow__label">
              {m.label}
              <span class={`badge tone-${m.tone}`}><span class="dot" />{m.id}</span>
            </span>
            <span class="modrow__blurb">{m.blurb}</span>
          </span>
        </label>
      ))
    }
  </fieldset>

  <div class="builder__out">
    <div class="builder__outhead">
      <span class="builder__os">Unix · macOS / Linux / WSL</span>
      <span class="badge tone-green"><span class="dot" />bash</span>
    </div>
    <div class="codeblock">
      <button class="copy" type="button" data-copy data-code={unixCmd} aria-label="Copy Unix command">copy</button>
      <pre><code><span class="cb-prompt">$ </span><span id="cmd-unix">{unixCmd}</span></code></pre>
    </div>
  </div>

  <div class="builder__out">
    <div class="builder__outhead">
      <span class="builder__os">Windows · PowerShell 7</span>
      <span class="badge tone-purple"><span class="dot" />pwsh</span>
    </div>
    <div class="codeblock">
      <button class="copy" type="button" data-copy data-code={winCmd} aria-label="Copy Windows command">copy</button>
      <pre><code><span class="cb-prompt">PS> </span><span id="cmd-win">{winCmd}</span></code></pre>
    </div>
  </div>

  <p class="builder__note muted">
    Two separate one-liners on purpose — bash and PowerShell don't share syntax, so a
    single “universal” pipe can't work in both shells. Pick the line for your OS.
  </p>
</div>

<style>
  .builder__head h3 {
    margin: 0 0 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }
  .builder__head .muted {
    margin: 0 0 1.25rem;
    font-size: 0.92rem;
    max-width: 64ch;
  }
  .builder__pulse {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: var(--tn-green);
    box-shadow: 0 0 0 0 rgba(158, 206, 106, 0.6);
    animation: builderPulse 1.8s ease-out infinite;
  }
  @keyframes builderPulse {
    to {
      box-shadow: 0 0 0 0.55rem rgba(158, 206, 106, 0);
    }
  }

  .builder__mods {
    border: 0;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .modrow {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--tn-bg-dark);
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .modrow:hover {
    border-color: var(--tn-border-bright);
  }
  .modrow:has(.modrow__cb:checked) {
    border-color: var(--tn-border-bright);
    background: var(--tn-surface);
  }
  .modrow:focus-within {
    outline: 2px solid var(--tn-blue);
    outline-offset: 2px;
  }
  .modrow__cb {
    margin-top: 0.2rem;
    width: 1.05rem;
    height: 1.05rem;
    accent-color: var(--tn-green);
    flex: none;
    cursor: pointer;
  }
  .modrow__body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .modrow__label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-weight: 600;
    color: #fff;
  }
  .modrow__blurb {
    font-size: 0.86rem;
    color: var(--text-dim);
  }

  .builder__out {
    margin-top: 1rem;
  }
  .builder__outhead {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
  }
  .builder__os {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }
  .codeblock .cb-prompt {
    color: var(--tn-green);
    user-select: none;
  }
  .codeblock code {
    word-break: break-all;
  }
  .builder__note {
    margin: 1rem 0 0;
    font-size: 0.82rem;
  }
</style>

<script>
  // Rebuild both one-liners from the checkbox state. Tokens are read from the
  // module list's own `data-id`s, so the client can only ever emit allowlisted
  // values — the same list the served scripts validate against.
  const root = document.getElementById('module-builder');
  if (root) {
    const base = (root.dataset.base ?? '').replace(/\/$/, '');
    const boxes = Array.from(root.querySelectorAll<HTMLInputElement>('.modrow__cb'));
    const unixEl = document.getElementById('cmd-unix');
    const winEl = document.getElementById('cmd-win');
    const unixCopy = root.querySelector<HTMLButtonElement>('[aria-label="Copy Unix command"]');
    const winCopy = root.querySelector<HTMLButtonElement>('[aria-label="Copy Windows command"]');

    const tokensFor = (platform: string): string =>
      boxes
        .filter((b) => b.checked && (b.dataset.platforms ?? '').split(',').includes(platform))
        .map((b) => b.dataset.id ?? '')
        .filter(Boolean)
        .join(',');

    const render = () => {
      const unixTokens = tokensFor('unix');
      const winTokens = tokensFor('windows');

      const unixCmd = unixTokens
        ? `curl -sS ${base}/install | bash -s -- ${unixTokens}`
        : '# select at least one Unix module above';
      const winCmd = winTokens
        ? `& ([scriptblock]::Create((irm '${base}/install.ps1'))) ${winTokens}`
        : '# select at least one Windows module above';

      if (unixEl) unixEl.textContent = unixCmd;
      if (winEl) winEl.textContent = winCmd;
      if (unixCopy) unixCopy.setAttribute('data-code', unixCmd);
      if (winCopy) winCopy.setAttribute('data-code', winCmd);
    };

    boxes.forEach((b) => b.addEventListener('change', render));
    render();
  }
</script>
