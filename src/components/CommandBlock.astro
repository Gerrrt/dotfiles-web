---
// A copy-to-clipboard code block. `code` is the raw text; `lang` only tweaks the
// shown prompt glyph. The copy button is wired by a global script in Base.astro.
interface Props {
  code: string;
  lang?: 'bash' | 'powershell';
  showPrompt?: boolean;
}
const { code, lang = 'bash', showPrompt = true } = Astro.props;
const prompt = lang === 'powershell' ? 'PS>' : '$';
const lines = code.split('\n');
---

<div class="codeblock">
  <button class="copy" type="button" data-copy data-code={code} aria-label="Copy command">
    <svg class="copy__icon copy__icon--clip" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
    <svg class="copy__icon copy__icon--check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
    <span class="copy__label">Copy</span>
  </button>
  {/* Each line is rendered on a single source line on purpose: inside a
      `white-space: pre` block, any indentation/newlines the template would add
      between these spans get rendered as literal blank lines, which is what
      previously opened large vertical gaps inside command blocks. */}
  <pre><code>{lines.map((line, i) => {
    const isComment = line.trimStart().startsWith('#');
    const showP = showPrompt && !isComment && line.trim() !== '';
    return <span class="cb-line">{showP && <span class="cb-prompt">{prompt} </span>}<span class:list={['cb-text', { 'cb-comment': isComment }]}>{line}</span>{i < lines.length - 1 ? '\n' : ''}</span>;
  })}</code></pre>
</div>

<style>
  .cb-prompt {
    color: var(--tn-green);
    user-select: none;
  }
  .cb-comment {
    color: var(--tn-comment);
  }
  .cb-text {
    color: var(--tn-fg);
  }
</style>
