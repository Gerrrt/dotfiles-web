---
// ArchitectureDiagram — a static, data-driven SVG of the subtree topology.
//
// The one fact the site never SHOWED: dotfiles-core is authored once and vendored
// into every machine repo via `git subtree` (full Core), while dotfiles-Windows
// mirrors only select Core assets — nvim/ and starship/ via their sync scripts
// (dashed edge), not the full subtree. Layout is computed from the
// real repo list in src/data/repos.ts, so adding a repo there updates this diagram
// — no hand-drawn drift. Pure inline SVG: no dependency, no hydration, Tokyo Night
// tokens only (matches the interactive-features design constraints).
import { repos, layerMeta } from '../data/repos';
import type { Layer } from '../data/repos';
import { driftFor, metrics } from '../data/metrics';
import type { DriftStatus } from '../data/metrics';

const accentVar: Record<string, string> = {
  purple: 'var(--tn-purple)',
  blue: 'var(--tn-blue)',
  cyan: 'var(--tn-cyan)',
  red: 'var(--tn-red)',
};

// Live vendoring drift (from generated.json): colour each edge by whether the repo
// carries Core's CURRENT release. 'unknown' stays neutral so an un-regenerated
// generated.json just renders the old static look — never a misleading red.
const driftColor: Record<DriftStatus, string | null> = {
  current: 'var(--tn-green)',
  behind: 'var(--tn-orange)',
  unknown: null,
};

const core = repos.find((r) => r.layer === 'core')!;
const order: Layer[] = ['os', 'role', 'host'];
const consumers = repos
  .filter((r) => r.layer !== 'core')
  .sort((a, b) => order.indexOf(a.layer) - order.indexOf(b.layer));

const short = (n: string) => n.replace(/^dotfiles-/, '');

// ── layout (viewBox units) ────────────────────────────────────────────────────
const W = 980;
const H = 470;
const padX = 28;
const N = consumers.length;
// Defensive (component is data-driven from repos.ts): never divide by zero — a
// core-only list renders just the hub — and never emit a negative/oversized node
// width as the fleet grows. Below ~56px nodes start to crowd but the SVG stays valid.
const slot = (W - 2 * padX) / Math.max(N, 1);
const nodeW = Math.max(56, Math.min(112, slot - 14));
const nodeH = 58;
const rowY = 320; // top edge of the consumer-node row
const coreW = 250;
const coreH = 62;
const coreX = W / 2 - coreW / 2;
const coreY = 40;
const coreCx = W / 2;
const coreBottom = coreY + coreH;

const nodes = consumers.map((r, i) => {
  const cx = padX + slot * (i + 0.5);
  const d = driftFor(r.name);
  return {
    name: r.name,
    label: short(r.name),
    layer: r.layer,
    sub: r.layer === 'role' ? (r.name === 'dotfiles-Defense' ? 'OS + defensive' : 'OS + offensive') : r.layer === 'host' ? 'nvim+starship' : layerMeta[r.layer].label,
    x: cx - nodeW / 2,
    cx,
    dashed: r.layer === 'host', // Windows: nvim + starship mirror, not the full subtree
    accent: accentVar[layerMeta[r.layer].accent],
    driftStatus: d.status,
    driftRef: d.ref, // the release/sha this repo currently carries
    driftColor: driftColor[d.status],
  };
});

// Only surface the drift legend/labels when generated.json actually carries the
// data (any repo resolved to current/behind) — otherwise the diagram stays in its
// neutral, pre-drift look.
const hasDrift = nodes.some((n) => n.driftStatus !== 'unknown');

// cubic bezier from the core hub's bottom-centre to each node's top-centre
const edge = (cx: number) => {
  const my = (coreBottom + rowY) / 2;
  return `M ${coreCx} ${coreBottom} C ${coreCx} ${my}, ${cx} ${my}, ${cx} ${rowY}`;
};
---

<figure class="arch-diagram">
  <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-labelledby="arch-dg-t arch-dg-d" preserveAspectRatio="xMidYMid meet">
    <title id="arch-dg-t">Core vendoring topology</title>
    <desc id="arch-dg-d">
      dotfiles-core is vendored into {consumers.filter((c) => c.layer !== 'host').length} machine
      repositories via git subtree (solid edges); dotfiles-Windows mirrors only the Neovim and
      starship configs via sync scripts (dashed edge). Edges are coloured by live vendoring drift — green when the
      repo carries Core's current release, orange when it is behind — from each repo's recorded
      provenance.
    </desc>

    <!-- edges: solid = full subtree, dashed = nvim-only mirror -->
    {
      nodes.map((n) => (
        <path
          d={edge(n.cx)}
          class={n.dashed ? 'arch-edge arch-edge--mirror' : 'arch-edge'}
          style={n.driftColor ? `stroke:${n.driftColor};opacity:0.85` : undefined}
          fill="none"
        />
      ))
    }

    <!-- core hub -->
    <g>
      <rect x={coreX} y={coreY} width={coreW} height={coreH} rx="10" class="arch-core" />
      <text x={coreCx} y={coreY + 26} class="arch-node__name arch-node__name--core" text-anchor="middle">
        {core.name}
      </text>
      <text x={coreCx} y={coreY + 45} class="arch-node__sub" text-anchor="middle">
        authored once · vendored via git subtree
      </text>
    </g>

    <!-- consumer nodes -->
    {
      nodes.map((n) => (
        <g>
          <rect
            x={n.x}
            y={rowY}
            width={nodeW}
            height={nodeH}
            rx="9"
            class="arch-node"
            style={`--accent:${n.accent}`}
          />
          <rect x={n.x} y={rowY} width="4" height={nodeH} rx="2" style={`fill:${n.accent}`} />
          <text x={n.cx} y={rowY + 26} class="arch-node__name" text-anchor="middle">
            {n.label}
          </text>
          <text x={n.cx} y={rowY + 43} class="arch-node__sub" text-anchor="middle">
            {n.sub}
          </text>
          {n.driftStatus !== 'unknown' && (
            <circle cx={n.cx} cy={rowY} r="4.5" class="arch-dot" style={`fill:${n.driftColor}`} />
          )}
          {n.driftRef && (
            <text x={n.cx} y={rowY + nodeH + 14} class="arch-ref" text-anchor="middle">{n.driftRef}</text>
          )}
        </g>
      ))
    }

    <!-- legend -->
    <g transform={`translate(${padX}, ${H - 70})`}>
      <line x1="0" y1="6" x2="34" y2="6" class="arch-edge" />
      <text x="42" y="10" class="arch-legend">git subtree — full Core, self-contained</text>
      <line x1="0" y1="30" x2="34" y2="30" class="arch-edge arch-edge--mirror" />
      <text x="42" y="34" class="arch-legend">nvim + starship mirror — sync scripts (Windows host)</text>

      {
        hasDrift && (
          <g>
            <circle cx="6" cy="54" r="4.5" style="fill:var(--tn-green)" />
            <text x="20" y="58" class="arch-legend">
              in sync with Core{metrics.drift?.coreVersion ? ` v${metrics.drift.coreVersion}` : ''}
            </text>
            <circle cx="220" cy="54" r="4.5" style="fill:var(--tn-orange)" />
            <text x="234" y="58" class="arch-legend">behind — run a sync</text>
          </g>
        )
      }

      <g transform={`translate(${W - 2 * padX - 366}, 0)`}>
        {
        ([['core', 'Core'], ['os', 'OS-native'], ['host', 'Host'], ['role', 'Role']] as [Layer, string][]).map(
          ([l, lbl], i) => (
            <g transform={`translate(${i * 92}, 0)`}>
              <rect x="0" y="0" width="12" height="12" rx="3" style={`fill:${accentVar[layerMeta[l].accent]}`} />
              <text x="18" y="10" class="arch-legend">{lbl}</text>
            </g>
          )
        )
        }
      </g>
    </g>
  </svg>
  <figcaption>
    One Core, vendored into {consumers.filter((c) => c.layer !== 'host').length} machine repos via
    <code>git subtree</code> — each clone is self-contained (no submodule init).
    <strong>dotfiles-Kali</strong> stacks a Role layer on its OS layer; <strong>dotfiles-Windows</strong>
    carries no <code>core/</code> subtree and mirrors only the Neovim and starship configs.
    {
      hasDrift && (
        <span>
          {' '}Edge colour tracks live vendoring drift — green = carrying Core
          {metrics.drift?.coreVersion ? ` v${metrics.drift.coreVersion}` : ''}, orange = behind (run
          a sync). Each repo's label shows the release it currently vendors.
        </span>
      )
    }
  </figcaption>
</figure>

<style>
  .arch-diagram {
    margin: 1.5rem 0 0;
  }
  .arch-diagram svg {
    width: 100%;
    height: auto;
    display: block;
    background: var(--tn-bg);
    border: 1px solid var(--tn-border);
    border-radius: 12px;
    padding: 0.5rem;
  }
  .arch-edge {
    stroke: var(--tn-purple);
    stroke-width: 1.6;
    opacity: 0.5;
  }
  .arch-edge--mirror {
    stroke: var(--tn-cyan);
    stroke-dasharray: 5 5;
    opacity: 0.7;
  }
  .arch-core {
    fill: color-mix(in srgb, var(--tn-purple) 14%, var(--tn-surface));
    stroke: var(--tn-purple);
    stroke-width: 1.5;
  }
  .arch-node {
    fill: var(--tn-surface);
    stroke: var(--accent, var(--tn-blue));
    stroke-width: 1.3;
  }
  .arch-node__name {
    fill: var(--tn-fg);
    font:
      600 14px/1 ui-monospace, 'SFMono-Regular', Menlo, monospace;
  }
  .arch-node__name--core {
    fill: var(--tn-purple);
    font-size: 15px;
  }
  .arch-node__sub {
    fill: var(--tn-muted);
    font:
      400 10.5px/1 ui-monospace, 'SFMono-Regular', Menlo, monospace;
  }
  .arch-legend {
    fill: var(--tn-comment);
    font:
      400 11px/1 ui-monospace, 'SFMono-Regular', Menlo, monospace;
  }
  /* carried-release label under each consumer node (live drift) */
  .arch-ref {
    fill: var(--tn-comment);
    font:
      600 9.5px/1 ui-monospace, 'SFMono-Regular', Menlo, monospace;
    letter-spacing: 0.02em;
  }
  /* sync dot where each edge meets its node; bg stroke keeps it crisp on the border */
  .arch-dot {
    stroke: var(--tn-bg);
    stroke-width: 1.5;
  }
  figcaption {
    color: var(--tn-muted);
    font-size: 0.85rem;
    line-height: 1.5;
    margin-top: 0.6rem;
  }
  figcaption code {
    color: var(--tn-cyan);
  }
  figcaption strong {
    color: var(--tn-fg);
    font-weight: 600;
  }
</style>
